title: "Hierarchical Statistical Analyzer"

version: "2.0.0"

date-released: 2026-05-12

type: software

authors:
  - family-names: "Terreau"
    given-names: "Sébastien"

repository-code: "https://github.com/sebastienleonmichel/hierarchical-statistical-analyzer"

